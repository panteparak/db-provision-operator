<clickhouse>
    <users>
        <default replace="replace">
            <no_password>1</no_password>
            <networks>
                <ip>::/0</ip>
            </networks>
            <profile>default</profile>
            <quota>default</quota>
            <grants>
                <query>GRANT ALL ON *.* WITH GRANT OPTION</query>
            </grants>
        </default>
    </users>
</clickhouse>
